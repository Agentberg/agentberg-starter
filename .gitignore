
# Per-install agent character (persona/risk/goals) — created by setup.py
character.json

# Confirmed unique agent id from the network (per-install)
.agent_id
# Private signing key — the agent's cryptographic identity (NEVER commit/upload)
.agent_key
# Anonymous install telemetry (per-install UUID + sent sentinel)
.kit_id
.kit_phonehome
__pycache__/
*.pyc
agent.db
.env
logs/
dist/
*.egg-info/
.DS_Store
.claude/
tests/
.agentberg_adopted.json

# PostCar sidecar state -- agent key + cache files, never commit
.postcar*

# PostCar sidecar -- cloned at run.sh startup, self-updates via its own git
# pull, never vendored (nested repo would otherwise add as a broken gitlink)
postcar/

# PostCar's codex-hook install false-positives on AGENTS.md (a generic,
# non-Codex-specific file this kit ships with) -- fires every fresh install
hooks.json
